@model MenStyle.Web.ViewModels.CheckoutViewModel
@using System.Net

@{
    ViewData["Title"] = "Thanh toán";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }

    var bankCode = "Eximbank";
    var accountNumber = "0377466477";
    var accountName = "HUYNH DUC THINH";

    var amount = Convert.ToInt64(Model.Total);
    var addInfo = $"Thanh toan don {Model.OrderCode}";
    var qrUrl =
        $"https://img.vietqr.io/image/{bankCode}-{accountNumber}-compact2.png?amount={amount}&addInfo={WebUtility.UrlEncode(addInfo)}&accountName={WebUtility.UrlEncode(accountName)}";
}

<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<main class="payment-page">
    <div class="container">

        <div class="payment-heading">
            <div>
                <p class="eyebrow">MENSTYLE CHECKOUT</p>
                <h1>Thanh toán đơn hàng</h1>
                <p>Kiểm tra thông tin giao hàng, xác nhận vị trí và chọn phương thức thanh toán.</p>
            </div>

            <a class="btn btn-outline" asp-controller="Cart" asp-action="Index">
                Quay lại giỏ hàng
            </a>
        </div>

        <form asp-controller="Cart" asp-action="Checkout" method="post" class="payment-layout" id="checkoutForm">
            @Html.AntiForgeryToken()

            <input asp-for="OrderCode" type="hidden" />

            <section class="payment-card">
                <h2>Thông tin giao hàng</h2>

                <div asp-validation-summary="ModelOnly" class="text-danger validation-box"></div>

                <div class="form-group">
                    <label asp-for="CustomerName"></label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Nhập họ tên người nhận" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="0909123456" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ShippingAddress">Địa chỉ giao hàng</label>

                    <div class="address-search-row">
                        <input asp-for="ShippingAddress"
                               id="shippingAddressInput"
                               class="form-control"
                               placeholder="Nhập địa chỉ giao hàng, ví dụ: 828 Sư Vạn Hạnh, Quận 10..." />

                        <button type="button" id="searchAddressBtn" class="address-search-btn">
                            Tìm trên bản đồ
                        </button>
                    </div>

                    <input asp-for="ShippingLatitude" type="hidden" id="shippingLatitude" />
                    <input asp-for="ShippingLongitude" type="hidden" id="shippingLongitude" />
                    <input asp-for="IsAddressConfirmed" type="hidden" id="isAddressConfirmed" />

                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>

                    <div id="mapConfirmBox" class="map-confirm-box">
                        <div id="shippingMap" class="shipping-map"></div>

                        <div class="map-confirm-info">
                            <strong>Xác nhận vị trí giao hàng</strong>

                            <p id="mapAddressText">
                                Nhập địa chỉ, tên đường hoặc quận. Ví dụ: 828 Sư Vạn Hạnh Q10, SVH Q10.
                            </p>

                            <div class="map-action-row">
                                <button type="button" id="useMyLocationBtn" class="map-location-btn">
                                    Dùng vị trí hiện tại
                                </button>

                                <button type="button" id="confirmAddressBtn" class="map-confirm-btn">
                                    Xác nhận địa chỉ
                                </button>

                                <button type="button" id="editAddressBtn" class="map-edit-btn" style="display:none;">
                                    Sửa địa chỉ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="note-toggle-box">
                    <div class="note-toggle-header">
                        <div>
                            <strong>Ghi chú đơn hàng</strong>
                            <p>Bật lên nếu bạn không có ghi chú gì cho đơn hàng.</p>
                        </div>

                        <label class="switch-toggle">
                            <input asp-for="NoNote" id="noNoteToggle" />
                            <span></span>
                        </label>
                    </div>

                    <div id="noteInputBox" class="note-input-box">
                        <label asp-for="Note"></label>

                        <textarea asp-for="Note"
                                  id="noteTextarea"
                                  class="form-control textarea-control"
                                  placeholder="Ví dụ: giao giờ hành chính, gọi trước khi giao..."></textarea>

                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                </div>

                <h2 class="payment-section-title">Phương thức thanh toán</h2>

                <div class="payment-method-list">
                    <label class="payment-method-card">
                        <input asp-for="PaymentMethod" type="radio" value="Thanh toán khi nhận hàng" />

                        <div>
                            <strong>Thanh toán khi nhận hàng</strong>
                            <span>Khách hàng trả tiền mặt khi nhận sản phẩm.</span>
                        </div>
                    </label>

                    <label class="payment-method-card">
                        <input asp-for="PaymentMethod" type="radio" value="Chuyển khoản ngân hàng" />

                        <div>
                            <strong>Chuyển khoản ngân hàng</strong>
                            <span>Admin xác nhận thanh toán sau khi nhận chuyển khoản.</span>
                        </div>
                    </label>
                </div>

                <span asp-validation-for="PaymentMethod" class="text-danger"></span>

                <div id="bankTransferBox" class="bank-info-box">
                    <strong>Quét mã QR để chuyển khoản</strong>

                    <div class="qr-payment-box">
                        <img src="@qrUrl"
                             alt="QR chuyển khoản @Model.OrderCode"
                             class="qr-payment-image" />

                        <div class="qr-payment-info">
                            <p><strong>Ngân hàng:</strong> @bankCode</p>
                            <p><strong>Số tài khoản:</strong> @accountNumber</p>
                            <p><strong>Chủ tài khoản:</strong> @accountName</p>
                            <p><strong>Số tiền:</strong> @FormatPrice(Model.Total)</p>
                            <p><strong>Nội dung CK:</strong> @addInfo</p>
                            <p><strong>Mã đơn hàng:</strong> @Model.OrderCode</p>
                        </div>
                    </div>
                </div>
            </section>

            <aside class="payment-summary">
                <h2>Tóm tắt đơn hàng</h2>

                <div class="payment-items">
                    @foreach (var item in Model.Items)
                    {
                        <div class="payment-item">
                            <img src="@item.ImageUrl" alt="@item.ProductName" />

                            <div>
                                <h3>@item.ProductName</h3>

                                <p>Số lượng: @item.Quantity</p>

                                @if (!string.IsNullOrWhiteSpace(item.SelectedSize) || !string.IsNullOrWhiteSpace(item.SelectedColor))
                                {
                                    <p>
                                        @if (!string.IsNullOrWhiteSpace(item.SelectedSize))
                                        {
                                            <span>Size: @item.SelectedSize</span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(item.SelectedColor))
                                        {
                                            <span> | Màu: @item.SelectedColor</span>
                                        }
                                    </p>
                                }

                                <strong>@FormatPrice(item.LineTotal)</strong>
                            </div>
                        </div>
                    }
                </div>

                <div class="summary-row">
                    <span>Số lượng</span>
                    <strong>@Model.TotalQuantity sản phẩm</strong>
                </div>

                <div class="summary-row">
                    <span>Tạm tính</span>
                    <strong>@FormatPrice(Model.Total)</strong>
                </div>

                <div class="summary-row">
                    <span>Phí vận chuyển</span>
                    <strong>Miễn phí</strong>
                </div>

                <div class="summary-total">
                    <span>Tổng thanh toán</span>
                    <strong>@FormatPrice(Model.Total)</strong>
                </div>

                <button type="submit" class="btn btn-primary full">
                    Xác nhận đặt hàng
                </button>
            </aside>
        </form>

    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        function toggleBankTransferBox() {
        const selectedPayment = document.querySelector('input[name="PaymentMethod"]:checked');
        const bankBox = document.getElementById("bankTransferBox");

        if (!selectedPayment || !bankBox) return;

        bankBox.style.display =
        selectedPayment.value === "Chuyển khoản ngân hàng"
        ? "block"
        : "none";
        }

        function setupPaymentMethod() {
        const radios = document.querySelectorAll('input[name="PaymentMethod"]');

        radios.forEach(radio => {
        radio.addEventListener("change", toggleBankTransferBox);
        });

        toggleBankTransferBox();
        }

        function setupNoNoteToggle() {
        const toggle = document.getElementById("noNoteToggle");
        const noteBox = document.getElementById("noteInputBox");
        const noteTextarea = document.getElementById("noteTextarea");

        if (!toggle || !noteBox || !noteTextarea) return;

        function updateNoteState() {
        if (toggle.checked) {
        noteTextarea.value = "";
        noteTextarea.disabled = true;
        noteBox.classList.add("is-disabled");
        } else {
        noteTextarea.disabled = false;
        noteBox.classList.remove("is-disabled");
        }
        }

        toggle.addEventListener("change", updateNoteState);
        updateNoteState();
        }

        function setupShippingMap() {
        if (typeof L === "undefined") {
        console.error("Leaflet chưa được tải.");
        return;
        }

        const defaultLat = 10.7769;
        const defaultLng = 106.7009;

        const addressInput = document.getElementById("shippingAddressInput");
        const latInput = document.getElementById("shippingLatitude");
        const lngInput = document.getElementById("shippingLongitude");
        const confirmedInput = document.getElementById("isAddressConfirmed");

        const mapBox = document.getElementById("mapConfirmBox");
        const mapAddressText = document.getElementById("mapAddressText");
        const useMyLocationBtn = document.getElementById("useMyLocationBtn");
        const confirmAddressBtn = document.getElementById("confirmAddressBtn");
        const editAddressBtn = document.getElementById("editAddressBtn");
        const checkoutForm = document.getElementById("checkoutForm");
        const searchAddressBtn = document.getElementById("searchAddressBtn");

        if (!addressInput || !latInput || !lngInput || !confirmedInput || !mapBox || !mapAddressText) {
        console.error("Thiếu element bản đồ trong Checkout.cshtml.");
        return;
        }

        let searchTimer = null;
        let lastSearchText = "";

        const oldLat = parseFloat(latInput.value);
        const oldLng = parseFloat(lngInput.value);

        const startLat = !Number.isNaN(oldLat) ? oldLat : defaultLat;
        const startLng = !Number.isNaN(oldLng) ? oldLng : defaultLng;

        const map = L.map("shippingMap").setView([startLat, startLng], 13);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap"
        }).addTo(map);

        const marker = L.marker([startLat, startLng], {
        draggable: true
        }).addTo(map);

        function stripAccent(value) {
        return (value || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/đ/g, "d")
        .replace(/Đ/g, "D");
        }

        function normalizeVietnameseAddress(input) {
        let value = (input || "").trim();

        value = value
        .replace(/\s+/g, " ")
        .replace(/\s*,\s*/g, ", ");

        value = value.replace(/\bq\.?\s*(\d+)/gi, "Quận $1");
        value = value.replace(/\bquan\s*(\d+)/gi, "Quận $1");

        value = value.replace(/\bp\.?\s*(\d+)/gi, "Phường $1");
        value = value.replace(/\bphuong\s*(\d+)/gi, "Phường $1");

        value = value.replace(/\btp\.?\s*hcm\b/gi, "Thành phố Hồ Chí Minh");
        value = value.replace(/\btphcm\b/gi, "Thành phố Hồ Chí Minh");
        value = value.replace(/\bhcm\b/gi, "Thành phố Hồ Chí Minh");
        value = value.replace(/\bsg\b/gi, "Thành phố Hồ Chí Minh");
        value = value.replace(/\bsaigon\b/gi, "Thành phố Hồ Chí Minh");
        value = value.replace(/\bsai gon\b/gi, "Thành phố Hồ Chí Minh");

        value = value.replace(/\bsvh\b/gi, "Sư Vạn Hạnh");
        value = value.replace(/\bsu\s+van\s+hanh\b/gi, "Sư Vạn Hạnh");
        value = value.replace(/\bsư\s+van\s+hạnh\b/gi, "Sư Vạn Hạnh");

        value = value.replace(/\bcmt8\b/gi, "Cách Mạng Tháng 8");
        value = value.replace(/\bcach\s+mang\s+thang\s+8\b/gi, "Cách Mạng Tháng 8");

        value = value.replace(/\bdbp\b/gi, "Điện Biên Phủ");
        value = value.replace(/\bdien\s+bien\s+phu\b/gi, "Điện Biên Phủ");

        value = value.replace(/\bltk\b/gi, "Lý Thường Kiệt");
        value = value.replace(/\bly\s+thuong\s+kiet\b/gi, "Lý Thường Kiệt");

        value = value.replace(/\bnvt\b/gi, "Nguyễn Văn Trỗi");
        value = value.replace(/\bntmk\b/gi, "Nguyễn Thị Minh Khai");

        const lowerNoAccent = stripAccent(value).toLowerCase();

        if (!lowerNoAccent.includes("ho chi minh")) {
        value += ", Thành phố Hồ Chí Minh";
        }

        return value;
        }

        function removeHouseNumber(address) {
        return address
        .replace(/^\s*\d+[a-zA-Z]?(\/\d+[a-zA-Z]?)?\s*,?\s*/i, "")
        .trim();
        }

        function getDistrictFromAddress(address) {
        const match = address.match(/quận\s*\d+/i);

        if (match) {
        return match[0];
        }

        const noAccent = stripAccent(address).toLowerCase();
        const fallback = noAccent.match(/quan\s*\d+/i);

        return fallback ? fallback[0].replace("quan", "Quận") : "";
        }

        function uniqueList(items) {
        return [...new Set(items.filter(x => x && x.trim().length > 0))];
        }

        function buildAddressQueries(rawAddress) {
        const normalized = normalizeVietnameseAddress(rawAddress);
        const noHouseNumber = removeHouseNumber(normalized);
        const district = getDistrictFromAddress(normalized);
        const streetOnly = noHouseNumber.split(",")[0]?.trim();

        const queries = [
        normalized,
        noHouseNumber,
        rawAddress + ", Thành phố Hồ Chí Minh"
        ];

        if (streetOnly && district) {
        queries.push(`${streetOnly}, ${district}, Thành phố Hồ Chí Minh`);
        queries.push(`Đường ${streetOnly}, ${district}, Thành phố Hồ Chí Minh`);
        }

        if (district) {
        queries.push(`${district}, Thành phố Hồ Chí Minh`);
        }

        return uniqueList(queries);
        }

        function scorePlace(place, originalAddress) {
        const placeName = stripAccent(place.display_name || "").toLowerCase();
        const original = stripAccent(normalizeVietnameseAddress(originalAddress || "")).toLowerCase();

        let score = Number(place.importance || 0);

        if (placeName.includes("ho chi minh")) {
        score += 5;
        }

        const district = stripAccent(getDistrictFromAddress(originalAddress)).toLowerCase();

        if (district && placeName.includes(district)) {
        score += 3;
        }

        const normalizedOriginal = normalizeVietnameseAddress(originalAddress);
        const noHouse = removeHouseNumber(normalizedOriginal);
        const streetOnly = stripAccent(noHouse.split(",")[0] || "").toLowerCase();

        if (streetOnly && placeName.includes(streetOnly)) {
        score += 4;
        }

        if (original.includes("su van hanh") && placeName.includes("su van hanh")) {
        score += 5;
        }

        return score;
        }

        async function geocodeQuery(query, originalAddress) {
        const url =
        "https://nominatim.openstreetmap.org/search?" +
        new URLSearchParams({
        format: "jsonv2",
        addressdetails: "1",
        limit: "5",
        countrycodes: "vn",
        "accept-language": "vi",
        viewbox: "106.45,10.95,106.90,10.60",
        bounded: "0",
        q: query
        });

        const response = await fetch(url);
        const results = await response.json();

        if (!Array.isArray(results) || results.length === 0) {
        return null;
        }

        results.sort((a, b) => scorePlace(b, originalAddress) - scorePlace(a, originalAddress));

        return results[0];
        }

        function setAddressConfirmed(isConfirmed) {
        confirmedInput.value = isConfirmed ? "true" : "false";

        if (isConfirmed) {
        mapBox.classList.add("is-confirmed");

        map.dragging.disable();
        map.touchZoom.disable();
        map.doubleClickZoom.disable();
        map.scrollWheelZoom.disable();
        map.boxZoom.disable();
        map.keyboard.disable();

        if (marker.dragging) {
        marker.dragging.disable();
        }

        if (confirmAddressBtn) confirmAddressBtn.style.display = "none";
        if (editAddressBtn) editAddressBtn.style.display = "inline-flex";

        mapAddressText.textContent =
        "Địa chỉ đã được xác nhận. Nếu muốn thay đổi, hãy bấm Sửa địa chỉ hoặc nhập lại địa chỉ.";
        } else {
        mapBox.classList.remove("is-confirmed");

        map.dragging.enable();
        map.touchZoom.enable();
        map.doubleClickZoom.enable();
        map.scrollWheelZoom.enable();
        map.boxZoom.enable();
        map.keyboard.enable();

        if (marker.dragging) {
        marker.dragging.enable();
        }

        if (confirmAddressBtn) confirmAddressBtn.style.display = "inline-flex";
        if (editAddressBtn) editAddressBtn.style.display = "none";
        }
        }

        async function reverseGeocodeAddress(lat, lng) {
        try {
        const response = await fetch(
        `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}&accept-language=vi`
        );

        const data = await response.json();

        if (data && data.display_name) {
        return data.display_name;
        }

        return "";
        } catch {
        return "";
        }
        }

        async function updateLocation(lat, lng, message, autoFillAddress = true) {
        latInput.value = lat;
        lngInput.value = lng;

        marker.setLatLng([lat, lng]);
        map.setView([lat, lng], 16);

        mapAddressText.textContent =
        message || "Đã chọn vị trí: " + lat.toFixed(6) + ", " + lng.toFixed(6);

        if (autoFillAddress) {
        mapAddressText.textContent = "Đang xác định địa chỉ từ vị trí đã chọn...";

        const foundAddress = await reverseGeocodeAddress(lat, lng);

        if (foundAddress) {
        addressInput.value = foundAddress;
        mapAddressText.textContent = "Đã xác định địa chỉ: " + foundAddress;
        } else {
        mapAddressText.textContent =
        "Đã chọn vị trí: " + lat.toFixed(6) + ", " + lng.toFixed(6) +
        ". Bạn có thể nhập thêm địa chỉ cụ thể nếu cần.";
        }
        }
        }

        async function searchAddressOnMap(address) {
        const keyword = address.trim();

        if (keyword.length < 3) {
        mapAddressText.textContent = "Vui lòng nhập địa chỉ rõ hơn để tìm trên bản đồ.";
        return;
        }

        if (keyword === lastSearchText) {
        return;
        }

        lastSearchText = keyword;

        mapAddressText.textContent = "Đang tìm địa chỉ trên bản đồ...";

        const queries = buildAddressQueries(keyword);

        try {
        let foundPlace = null;

        for (const query of queries) {
        foundPlace = await geocodeQuery(query, keyword);

        if (foundPlace) {
        break;
        }
        }

        if (!foundPlace) {
        mapAddressText.textContent =
        "Chưa tìm thấy địa chỉ này. Bạn có thể nhập tên đường + quận, hoặc bấm trực tiếp trên bản đồ để chọn vị trí.";
        return;
        }

        const lat = parseFloat(foundPlace.lat);
        const lng = parseFloat(foundPlace.lon);

        if (Number.isNaN(lat) || Number.isNaN(lng)) {
        mapAddressText.textContent = "Không lấy được tọa độ từ địa chỉ này.";
        return;
        }

        await updateLocation(
        lat,
        lng,
        "Bản đồ đã di chuyển tới khu vực phù hợp. Hãy kiểm tra marker rồi bấm Xác nhận địa chỉ.",
        false
        );
        } catch {
        mapAddressText.textContent =
        "Không thể tìm địa chỉ lúc này. Bạn có thể chọn vị trí trực tiếp trên bản đồ.";
        }
        }

        function scheduleAddressSearch() {
        setAddressConfirmed(false);

        clearTimeout(searchTimer);

        searchTimer = setTimeout(function () {
        searchAddressOnMap(addressInput.value);
        }, 1000);
        }

        addressInput.addEventListener("input", scheduleAddressSearch);

        if (searchAddressBtn) {
        searchAddressBtn.addEventListener("click", function () {
        setAddressConfirmed(false);
        searchAddressOnMap(addressInput.value);
        });
        }

        map.on("click", async function (e) {
        if (confirmedInput.value === "true") return;

        await updateLocation(e.latlng.lat, e.latlng.lng, null, true);
        });

        marker.on("dragend", async function () {
        if (confirmedInput.value === "true") return;

        const position = marker.getLatLng();

        await updateLocation(
        position.lat,
        position.lng,
        "Bạn đã kéo marker. Đang xác định địa chỉ mới...",
        true
        );
        });

        if (useMyLocationBtn) {
        useMyLocationBtn.addEventListener("click", function () {
        setAddressConfirmed(false);

        if (!navigator.geolocation) {
        mapAddressText.textContent = "Trình duyệt không hỗ trợ lấy vị trí hiện tại.";
        return;
        }

        mapAddressText.textContent = "Đang lấy vị trí hiện tại...";

        navigator.geolocation.getCurrentPosition(
        async function (position) {
        await updateLocation(
        position.coords.latitude,
        position.coords.longitude,
        "Đã lấy vị trí hiện tại. Đang xác định địa chỉ...",
        true
        );
        },
        function () {
        mapAddressText.textContent =
        "Không thể lấy vị trí hiện tại. Bạn hãy bấm trực tiếp trên bản đồ.";
        }
        );
        });
        }

        if (confirmAddressBtn) {
        confirmAddressBtn.addEventListener("click", async function () {
        const hasLocation = latInput.value && lngInput.value;

        if (!hasLocation) {
        mapAddressText.textContent = "Vui lòng chọn vị trí trên bản đồ trước khi xác nhận.";
        return;
        }

        if (!addressInput.value.trim()) {
        mapAddressText.textContent = "Đang tự xác định địa chỉ từ bản đồ...";

        const foundAddress = await reverseGeocodeAddress(
        parseFloat(latInput.value),
        parseFloat(lngInput.value)
        );

        if (foundAddress) {
        addressInput.value = foundAddress;
        }
        }

        if (!addressInput.value.trim()) {
        mapAddressText.textContent =
        "Không tự xác định được địa chỉ. Bạn hãy nhập địa chỉ giao hàng vào ô phía trên.";
        addressInput.focus();
        return;
        }

        setAddressConfirmed(true);
        });
        }

        if (editAddressBtn) {
        editAddressBtn.addEventListener("click", function () {
        setAddressConfirmed(false);
        addressInput.focus();
        mapAddressText.textContent = "Bạn có thể sửa địa chỉ hoặc chọn lại vị trí trên bản đồ.";
        });
        }

        if (checkoutForm) {
        checkoutForm.addEventListener("submit", function (e) {
        if (confirmedInput.value !== "true") {
        e.preventDefault();
        mapAddressText.textContent = "Vui lòng bấm Xác nhận địa chỉ trước khi đặt hàng.";
        mapAddressText.scrollIntoView({ behavior: "smooth", block: "center" });
        }
        });
        }

        if (!Number.isNaN(oldLat) && !Number.isNaN(oldLng)) {
        marker.setLatLng([oldLat, oldLng]);
        map.setView([oldLat, oldLng], 16);
        mapAddressText.textContent = "Đã tải lại vị trí giao hàng trước đó.";
        } else if (addressInput.value.trim().length >= 3) {
        setTimeout(function () {
        searchAddressOnMap(addressInput.value);
        }, 600);
        }

        setAddressConfirmed(confirmedInput.value === "true");

        setTimeout(function () {
        map.invalidateSize();
        }, 300);
        }

        document.addEventListener("DOMContentLoaded", function () {
        setupPaymentMethod();
        setupNoNoteToggle();
        setupShippingMap();
        });
    </script>
}