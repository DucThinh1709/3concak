@model MenStyle.Web.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Giỏ hàng";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main class="cart-page">
    <div class="container">
        <div class="cart-heading">
            <div>
                <p class="eyebrow">MENSTYLE Cart</p>
                <h1>Giỏ hàng của bạn</h1>
                <p>Kiểm tra sản phẩm, size, màu sắc, số lượng và tổng tiền trước khi đặt hàng.</p>
            </div>

            <a class="btn btn-outline"
               asp-controller="Home"
               asp-action="SanPham">
                Tiếp tục mua sắm
            </a>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="flash-message success">@successMessage</div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="flash-message error">@errorMessage</div>
        }

        @if (!Model.Items.Any())
        {
            <div class="empty-cart">
                <div class="empty-icon">🛒</div>
                <h2>Giỏ hàng đang trống</h2>
                <p>Hãy quay lại trang sản phẩm và chọn món đồ bạn thích.</p>

                <a class="btn btn-primary"
                   asp-controller="Home"
                   asp-action="SanPham">
                    Xem sản phẩm
                </a>
            </div>
        }
        else
        {
            <div class="cart-layout">
                <div class="cart-card">
                    <div class="cart-table">
                        @foreach (var item in Model.Items)
                        {
                            var hasSize = !string.IsNullOrWhiteSpace(item.SelectedSize);
                            var hasColor = !string.IsNullOrWhiteSpace(item.SelectedColor);

                            <div class="cart-row">
                                <div class="cart-product">
                                    <img src="@item.ImageUrl" alt="@item.ProductName" />

                                    <div class="cart-product-info">
                                        <h3>@item.ProductName</h3>

                                        <p class="cart-category">@item.CategoryName</p>

                                        <div class="cart-variant-info">
                                            <span class="cart-variant-badge">
                                                Size: @(hasSize ? item.SelectedSize : "Chưa chọn")
                                            </span>

                                            <span class="cart-variant-badge">
                                                Màu: @(hasColor ? item.SelectedColor : "Chưa chọn")
                                            </span>
                                        </div>

                                        <strong class="cart-item-price">
                                            @FormatPrice(item.Price)
                                        </strong>
                                    </div>
                                </div>

                                <div class="qty-box">
                                    <form asp-controller="Cart"
                                          asp-action="Decrease"
                                          asp-route-id="@item.CartItemId"
                                          method="post">
                                        @Html.AntiForgeryToken()

                                        <button type="submit" aria-label="Giảm số lượng">
                                            −
                                        </button>
                                    </form>

                                    <span>@item.Quantity</span>

                                    <form asp-controller="Cart"
                                          asp-action="Increase"
                                          asp-route-id="@item.CartItemId"
                                          method="post">
                                        @Html.AntiForgeryToken()

                                        <button type="submit" aria-label="Tăng số lượng">
                                            +
                                        </button>
                                    </form>
                                </div>

                                <div class="cart-line-total">
                                    @FormatPrice(item.LineTotal)
                                </div>

                                <form asp-controller="Cart"
                                      asp-action="Remove"
                                      asp-route-id="@item.CartItemId"
                                      method="post">
                                    @Html.AntiForgeryToken()

                                    <button class="remove-btn" type="submit">
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>

                <aside class="cart-summary">
                    <h2>Tóm tắt đơn hàng</h2>

                    <div class="summary-row">
                        <span>Số lượng</span>
                        <strong>@Model.TotalQuantity sản phẩm</strong>
                    </div>

                    <div class="summary-row">
                        <span>Tạm tính</span>
                        <strong>@FormatPrice(Model.Total)</strong>
                    </div>

                    <div class="summary-row">
                        <span>Phí vận chuyển</span>
                        <strong>Miễn phí</strong>
                    </div>

                    <div class="summary-total">
                        <span>Tổng cộng</span>
                        <strong>@FormatPrice(Model.Total)</strong>
                    </div>

                    <a class="btn btn-primary full"
                       asp-controller="Cart"
                       asp-action="Checkout">
                        Tiến hành thanh toán
                    </a>

                    <form asp-controller="Cart"
                          asp-action="Clear"
                          method="post">
                        @Html.AntiForgeryToken()

                        <button class="clear-cart-btn" type="submit">
                            Xóa toàn bộ giỏ hàng
                        </button>
                    </form>
                </aside>
            </div>
        }
    </div>
</main>