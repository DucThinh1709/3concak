@model MenStyle.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-section">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Đăng nhập</h1>
            <p>Đăng nhập để mua sắm và quản lý đơn hàng của bạn.</p>
        </div>

        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="form-group">
                <label asp-for="LoginIdentifier"></label>
                <input asp-for="LoginIdentifier"
                       class="form-control"
                       placeholder="Nhập email hoặc số điện thoại" />
                <span asp-validation-for="LoginIdentifier" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password"
                       class="form-control"
                       placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn-auth">
                Đăng nhập
            </button>
        </form>

        <div class="auth-footer">
            <span>Chưa có tài khoản?</span>
            <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}