@model MenStyle.Web.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<main class="auth-page">
    <section class="auth-card compact">
        <div class="auth-intro">
            <p class="eyebrow">Welcome Back</p>
            <h1>Đăng nhập MENSTYLE</h1>
            <p>Dùng tài khoản đã đăng ký để vào website. Tài khoản demo admin: <strong>admin@menstyle.vn</strong> / <strong>Admin@123</strong>.</p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <label asp-for="Email"></label>
            <input asp-for="Email" placeholder="customer@gmail.com" />
            <span asp-validation-for="Email" class="field-validation"></span>

            <label asp-for="Password"></label>
            <input asp-for="Password" placeholder="Nhập mật khẩu" />
            <span asp-validation-for="Password" class="field-validation"></span>

            <label class="remember-row">
                <input asp-for="RememberMe" />
                <span>Ghi nhớ đăng nhập</span>
            </label>

            <button type="submit" class="btn btn-primary full">Đăng nhập</button>

            <p class="auth-switch">
                Chưa có tài khoản?
                <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@returnUrl">Tạo tài khoản</a>
            </p>
        </form>
    </section>
</main>
