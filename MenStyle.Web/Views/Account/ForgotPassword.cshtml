@model MenStyle.Web.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-page">
    <div class="auth-shell forgot-shell">
        <div class="auth-visual">
            <a class="auth-logo" asp-controller="Home" asp-action="Index">
                MEN<span>STYLE</span>
            </a>

            <div class="auth-visual-content">
                <p class="eyebrow">Password Recovery</p>
                <h1>Khôi phục mật khẩu</h1>
                <p>
                    Nhập email hoặc số điện thoại đã đăng ký để tạo mật khẩu mới cho tài khoản MENSTYLE.
                </p>
            </div>
        </div>

        <div class="auth-panel">
            <div class="auth-header">
                <p>Quên mật khẩu?</p>
                <h2>Tìm tài khoản của bạn</h2>
                <span>Hệ thống sẽ kiểm tra tài khoản và chuyển sang trang đặt lại mật khẩu.</span>
            </div>

            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="flash-message error">@errorMessage</div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger validation-box"></div>

                <div class="form-group">
                    <label asp-for="LoginIdentifier"></label>
                    <div class="input-icon">
                        <span>✉</span>
                        <input asp-for="LoginIdentifier"
                               class="form-control"
                               placeholder="Email hoặc số điện thoại" />
                    </div>
                    <span asp-validation-for="LoginIdentifier" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-auth">
                    Tiếp tục
                </button>
            </form>

            <div class="auth-footer">
                <span>Đã nhớ mật khẩu?</span>
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}