@using System.Globalization
@model MenStyle.Web.Models.CustomerOrder

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }

    var hasLocation = Model.ShippingLatitude != null && Model.ShippingLongitude != null;

    var latitudeText = hasLocation
        ? Model.ShippingLatitude!.Value.ToString(CultureInfo.InvariantCulture)
        : "";

    var longitudeText = hasLocation
        ? Model.ShippingLongitude!.Value.ToString(CultureInfo.InvariantCulture)
        : "";

    var openStreetMapUrl = hasLocation
        ? $"https://www.openstreetmap.org/?mlat={latitudeText}&mlon={longitudeText}#map=17/{latitudeText}/{longitudeText}"
        : "";
}

<main class="order-detail-page">
    <section class="order-detail-hero section-padding">
        <div class="container">
            <div class="order-detail-hero-card">
                <p class="eyebrow">My Order</p>
                <h1>@Model.OrderCode</h1>
                <p>Thông tin chi tiết đơn hàng của bạn tại MENSTYLE.</p>

                <div class="order-hero-meta">
                    <span class="status-chip">@Model.Status</span>

                    @if (!string.IsNullOrWhiteSpace(Model.PaymentStatus))
                    {
                        <span class="payment-chip">@Model.PaymentStatus</span>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="order-detail-body">
        <div class="container">
            <div class="order-detail-layout">

                <div class="order-detail-left">
                    <div class="order-block">
                        <div class="order-block-head">
                            <h2>Sản phẩm đã đặt</h2>
                            <span>@Model.Items.Count sản phẩm</span>
                        </div>

                        <div class="order-items">
                            @foreach (var item in Model.Items)
                            {
                                var imageUrl = !string.IsNullOrWhiteSpace(item.SelectedImageUrl)
                                    ? item.SelectedImageUrl
                                    : "/images/products/default-product.jpg";

                                <div class="order-item-card">
                                    <div class="order-item-image">
                                        <img src="@imageUrl" alt="@item.ProductName" />
                                    </div>

                                    <div class="order-item-info">
                                        <div class="order-item-top">
                                            <h3>@item.ProductName</h3>
                                            <strong>@FormatPrice(item.LineTotal)</strong>
                                        </div>

                                        <div class="order-item-meta">
                                            <span>Số lượng: @item.Quantity</span>
                                            <span>Đơn giá: @FormatPrice(item.Price)</span>
                                        </div>

                                        <div class="order-item-variants">
                                            @if (!string.IsNullOrWhiteSpace(item.SelectedSize))
                                            {
                                                <span class="variant-badge">Size: @item.SelectedSize</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.SelectedColor))
                                            {
                                                <span class="variant-badge">Màu: @item.SelectedColor</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (hasLocation)
                    {
                        <div class="order-block">
                            <div class="order-block-head">
                                <h2>Bản đồ giao hàng</h2>

                                <a class="map-open-link"
                                   href="@openStreetMapUrl"
                                   target="_blank"
                                   rel="noopener">
                                    Mở bản đồ
                                </a>
                            </div>

                            <div class="order-map-box">
                                <iframe src="https://www.openstreetmap.org/export/embed.html?bbox=@longitudeText,@latitudeText,@longitudeText,@latitudeText&amp;layer=mapnik&amp;marker=@latitudeText,@longitudeText"
                                        loading="lazy">
                                </iframe>
                            </div>

                            <div class="order-location-note">
                                <strong>Tọa độ đã xác nhận:</strong>
                                <span>@latitudeText, @longitudeText</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Note))
                    {
                        <div class="order-block">
                            <div class="order-block-head">
                                <h2>Ghi chú đơn hàng</h2>
                            </div>

                            <div class="order-note-box">
                                @Model.Note
                            </div>
                        </div>
                    }
                </div>

                <aside class="order-detail-right">
                    <div class="order-summary-card">
                        <h2>Thông tin đơn hàng</h2>

                        <div class="summary-info-list">
                            <div class="summary-info-row">
                                <span>Khách hàng</span>
                                <strong>@Model.CustomerName</strong>
                            </div>

                            <div class="summary-info-row">
                                <span>Số điện thoại</span>
                                <strong>@Model.PhoneNumber</strong>
                            </div>

                            <div class="summary-info-row">
                                <span>Địa chỉ</span>
                                <strong>@Model.ShippingAddress</strong>
                            </div>

                            @if (hasLocation)
                            {
                                <div class="summary-info-row">
                                    <span>Vĩ độ</span>
                                    <strong>@latitudeText</strong>
                                </div>

                                <div class="summary-info-row">
                                    <span>Kinh độ</span>
                                    <strong>@longitudeText</strong>
                                </div>

                                <div class="summary-info-row">
                                    <span>Vị trí</span>
                                    <strong>
                                        <a class="summary-map-link"
                                           href="@openStreetMapUrl"
                                           target="_blank"
                                           rel="noopener">
                                            Xem trên bản đồ
                                        </a>
                                    </strong>
                                </div>
                            }
                            else
                            {
                                <div class="summary-info-row">
                                    <span>Vị trí</span>
                                    <strong>Chưa xác nhận bản đồ</strong>
                                </div>
                            }

                            <div class="summary-info-row">
                                <span>Ngày đặt</span>
                                <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                            </div>

                            <div class="summary-info-row">
                                <span>Trạng thái đơn</span>
                                <strong class="text-status">@Model.Status</strong>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Model.PaymentMethod))
                            {
                                <div class="summary-info-row">
                                    <span>Thanh toán</span>
                                    <strong>@Model.PaymentMethod</strong>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(Model.PaymentStatus))
                            {
                                <div class="summary-info-row">
                                    <span>Trạng thái thanh toán</span>
                                    <strong>@Model.PaymentStatus</strong>
                                </div>
                            }
                        </div>

                        <div class="summary-total-box">
                            <span>Tổng tiền</span>
                            <strong>@FormatPrice(Model.TotalAmount)</strong>
                        </div>

                        <div class="order-detail-actions">
                            <a class="btn btn-outline"
                               asp-controller="Account"
                               asp-action="MyOrders">
                                Quay lại đơn hàng của tôi
                            </a>

                            <a class="btn btn-primary"
                               asp-controller="Home"
                               asp-action="SanPham">
                                Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </aside>

            </div>
        </div>
    </section>
</main>