@model MenStyle.Web.Models.CustomerOrder

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main class="order-success-page">
    <div class="container">

        <section class="order-success-card">
            <p class="eyebrow">MY ORDER</p>
            <h1>@Model.OrderCode</h1>
            <p class="success-desc">
                Thông tin chi tiết đơn hàng của bạn tại MENSTYLE.
            </p>
        </section>

        <section class="order-detail-layout">
            <div class="order-detail-main">
                <div class="order-box">
                    <h2>Sản phẩm đã đặt</h2>

                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item-row">
                            <div>
                                <h3>@item.ProductName</h3>
                                <p>Số lượng: @item.Quantity</p>
                                <p>Đơn giá: @FormatPrice(item.Price)</p>
                            </div>

                            <strong>@FormatPrice(item.LineTotal)</strong>
                        </div>
                    }
                </div>
            </div>

            <aside class="order-detail-side">
                <div class="order-box">
                    <h2>Thông tin đơn hàng</h2>

                    <div class="info-row">
                        <span>Khách hàng</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div class="info-row">
                        <span>Số điện thoại</span>
                        <strong>@Model.PhoneNumber</strong>
                    </div>

                    <div class="info-row">
                        <span>Địa chỉ</span>
                        <strong>@Model.ShippingAddress</strong>
                    </div>

                    <div class="info-row">
                        <span>Ngày đặt</span>
                        <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>

                    <div class="info-row">
                        <span>Trạng thái</span>
                        <strong class="order-status">@Model.Status</strong>
                    </div>

                    <div class="order-total-row">
                        <span>Tổng tiền</span>
                        <strong>@FormatPrice(Model.TotalAmount)</strong>
                    </div>

                    <a class="btn btn-outline full"
                       asp-controller="Account"
                       asp-action="MyOrders">
                        Quay lại đơn hàng của tôi
                    </a>
                </div>
            </aside>
        </section>

    </div>
</main>