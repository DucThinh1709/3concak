@model MenStyle.Web.ViewModels.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<main class="auth-page">
    <section class="auth-card">
        <div class="auth-intro">
            <p class="eyebrow">MENSTYLE Account</p>
            <h1>Tạo tài khoản khách hàng</h1>
            <p>Thông tin đăng ký sẽ được lưu vào SQL Server trong bảng <strong>AspNetUsers</strong> thông qua ASP.NET Core Identity.</p>
        </div>

        <form asp-action="Register" asp-route-returnUrl="@returnUrl" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <label asp-for="FullName"></label>
            <input asp-for="FullName" placeholder="Nguyễn Văn A" />
            <span asp-validation-for="FullName" class="field-validation"></span>

            <label asp-for="Email"></label>
            <input asp-for="Email" placeholder="customer@gmail.com" />
            <span asp-validation-for="Email" class="field-validation"></span>

            <label asp-for="PhoneNumber"></label>
            <input asp-for="PhoneNumber" placeholder="0909123456" />
            <span asp-validation-for="PhoneNumber" class="field-validation"></span>

            <label asp-for="Address"></label>
            <input asp-for="Address" placeholder="Địa chỉ nhận hàng" />
            <span asp-validation-for="Address" class="field-validation"></span>

            <label asp-for="Password"></label>
            <input asp-for="Password" placeholder="Ví dụ: abc123" />
            <span asp-validation-for="Password" class="field-validation"></span>

            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" placeholder="Nhập lại mật khẩu" />
            <span asp-validation-for="ConfirmPassword" class="field-validation"></span>

            <button type="submit" class="btn btn-primary full">Đăng ký</button>

            <p class="auth-switch">
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">Đăng nhập ngay</a>
            </p>
        </form>
    </section>
</main>
