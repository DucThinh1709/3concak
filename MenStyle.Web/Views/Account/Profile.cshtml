@model MenStyle.Web.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Tài khoản cá nhân";
}

<main class="profile-page">
    <div class="container">

        <section class="profile-hero">
            <div>
                <p class="eyebrow">Customer Account</p>
                <h1>Tài khoản của tôi</h1>
                <p>
                    Quản lý thông tin cá nhân, địa chỉ giao hàng và thông tin liên hệ của bạn.
                </p>
            </div>
        </section>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="flash-message success">@successMessage</div>
        }

        <section class="profile-layout">

            <aside class="profile-sidebar">
                <div class="profile-user-card">
                    <div class="profile-avatar small" id="sideAvatarPreview">
                        @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="Ảnh đại diện" />
                        }
                        else
                        {
                            <span>@(string.IsNullOrWhiteSpace(Model.FullName) ? "M" : Model.FullName.Trim()[0].ToString().ToUpper())</span>
                        }
                    </div>

                    <h2>@Model.FullName</h2>
                    <p>@Model.Email</p>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="profile-badge admin">
                            <span></span>
                            Tài khoản quản trị
                        </div>
                    }
                    else
                    {
                        <div class="profile-badge customer">
                            <span></span>
                            Tài khoản khách hàng
                        </div>
                    }
                </div>

                <div class="profile-menu">
                    <a class="active" href="#">Thông tin cá nhân</a>
                    <a asp-controller="Home" asp-action="SanPham">Tiếp tục mua sắm</a>
                    <a asp-controller="Cart" asp-action="Index">Giỏ hàng của tôi</a>
                </div>
            </aside>

            <div class="profile-content">
                <div class="profile-card">
                    <div class="profile-card-head">
                        <div>
                            <p class="eyebrow">Profile Details</p>
                            <h2>Thông tin cá nhân</h2>
                        </div>
                    </div>

                    <form id="profileForm" asp-controller="Account" asp-action="Profile" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger validation-box"></div>
                        <div class="avatar-edit-panel">
                            <div class="avatar-edit-preview" id="formAvatarPreview">
                                @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                                {
                                    <img src="@Model.AvatarUrl" alt="Ảnh đại diện" />
                                }
                                else
                                {
                                    <span>@(string.IsNullOrWhiteSpace(Model.FullName) ? "M" : Model.FullName.Trim()[0].ToString().ToUpper())</span>
                                }
                            </div>

                            <div class="avatar-edit-content">
                                <h3>Ảnh đại diện</h3>
                                <p>Chọn ảnh mới để cập nhật ảnh đại diện tài khoản.</p>

                                <label class="avatar-upload-btn" for="avatarFileInput">
                                    Đổi ảnh đại diện
                                </label>

                                <input asp-for="AvatarFile"
                                       id="avatarFileInput"
                                       type="file"
                                       accept="image/png,image/jpeg,image/webp" />

                                <span asp-validation-for="AvatarFile" class="text-danger"></span>

                                <small>Chấp nhận JPG, PNG, WEBP. Tối đa 2MB.</small>
                            </div>
                        </div>

                        <div class="profile-grid">
                            <div class="form-group">
                                <label asp-for="FullName"></label>
                                <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Email</label>
                                <input value="@Model.Email" class="form-control readonly-input" readonly />
                                <small>Email dùng để đăng nhập, không chỉnh sửa tại đây.</small>
                            </div>

                            <div class="form-group">
                                <label asp-for="PhoneNumber"></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Gender"></label>
                                <select asp-for="Gender" class="form-control">
                                    <option value="">-- Chọn giới tính --</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>

                            <div class="form-group full-row">
                                <label asp-for="Address"></label>
                                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ giao hàng" />
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>Ngày tạo tài khoản</label>
                                <input value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")" class="form-control readonly-input" readonly />
                            </div>

                            <div class="profile-field">
                                <label>Loại tài khoản</label>

                                <div class="form-control locked-display">
                                    @(User.IsInRole("Admin") ? "Quản trị viên" : "Khách hàng")
                                </div>
                            </div>
                        </div>

                        <div class="profile-actions">
                            <button type="button" class="btn btn-primary" onclick="openConfirmSaveModal()">
                                Lưu thông tin
                            </button>

                            <a class="btn btn-outline" asp-controller="Home" asp-action="Index">
                                Về trang chủ
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </section>

    </div>
</main>

<div id="confirmSaveModal" class="profile-modal-overlay">
    <div class="profile-modal">
        <div class="modal-icon">?</div>

        <h2>Xác nhận lưu thông tin</h2>

        <p>
            Bạn có chắc chắn muốn lưu các thay đổi thông tin cá nhân vào hệ thống không?
        </p>

        <div class="modal-actions">
            <button type="button" class="btn btn-outline" onclick="closeConfirmSaveModal()">
                Hủy
            </button>

            <button type="button" class="btn btn-primary" onclick="submitProfileForm()">
                Đồng ý lưu
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function openConfirmSaveModal() {
            const form = document.getElementById("profileForm");

            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            document.getElementById("confirmSaveModal").classList.add("show");
        }

        function closeConfirmSaveModal() {
            document.getElementById("confirmSaveModal").classList.remove("show");
        }

        function submitProfileForm() {
            document.getElementById("profileForm").submit();
        }
        function setAvatarPreview(containerId, imageUrl) {
            const container = document.getElementById(containerId);

            if (!container) return;

            container.innerHTML = "";

            const img = document.createElement("img");
            img.src = imageUrl;
            img.alt = "Ảnh đại diện";

            container.appendChild(img);
        }

        document.addEventListener("DOMContentLoaded", function () {
            const avatarInput = document.getElementById("avatarFileInput");

            if (!avatarInput) return;

            avatarInput.addEventListener("change", function () {
                const file = this.files && this.files[0];

                if (!file) return;

                const allowedTypes = ["image/jpeg", "image/png", "image/webp"];

                if (!allowedTypes.includes(file.type)) {
                    alert("Chỉ cho phép ảnh JPG, PNG hoặc WEBP.");
                    this.value = "";
                    return;
                }

                if (file.size > 2 * 1024 * 1024) {
                    alert("Ảnh đại diện không được vượt quá 2MB.");
                    this.value = "";
                    return;
                }

                const imageUrl = URL.createObjectURL(file);

                setAvatarPreview("sideAvatarPreview", imageUrl);
                setAvatarPreview("formAvatarPreview", imageUrl);
            });
        });
    </script>
}