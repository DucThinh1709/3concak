@model MenStyle.Web.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<section class="auth-page">
    <div class="auth-shell forgot-shell">
        <div class="auth-visual">
            <a class="auth-logo" asp-controller="Home" asp-action="Index">
                MEN<span>STYLE</span>
            </a>

            <div class="auth-visual-content">
                <p class="eyebrow">Reset Password</p>
                <h1>Tạo mật khẩu mới</h1>
                <p>
                    Mật khẩu mới nên có ít nhất 6 ký tự và không nên trùng với mật khẩu cũ.
                </p>
            </div>
        </div>

        <div class="auth-panel">
            <div class="auth-header">
                <p>Bảo mật tài khoản</p>
                <h2>Đặt lại mật khẩu</h2>
                <span>Nhập mật khẩu mới cho tài khoản của bạn.</span>
            </div>

            <form asp-action="ResetPassword" asp-controller="Account" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger validation-box"></div>

                <input asp-for="UserId" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div class="form-group">
                    <label asp-for="NewPassword"></label>
                    <div class="input-icon">
                        <span>🔒</span>
                        <input asp-for="NewPassword"
                               class="form-control"
                               placeholder="Mật khẩu mới" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword"></label>
                    <div class="input-icon">
                        <span>✓</span>
                        <input asp-for="ConfirmPassword"
                               class="form-control"
                               placeholder="Nhập lại mật khẩu mới" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-auth">
                    Đổi mật khẩu
                </button>
            </form>

            <div class="auth-footer">
                <span>Quay lại</span>
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}