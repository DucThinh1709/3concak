@model MenStyle.Web.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Sản phẩm";

    var isAdmin = User.Identity?.IsAuthenticated == true && User.IsInRole("Admin");

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main class="product-page">

    <section class="product-hero section-padding">
        <div class="container">
            <div class="product-hero-content">
                <p class="eyebrow">MENSTYLE SHOP</p>

                <h1>Sản phẩm thời trang nam</h1>

                <p>
                    Khám phá các mẫu áo thun, áo sơ mi, quần nam và áo khoác được chọn lọc
                    dành riêng cho phong cách nam hiện đại.
                </p>
            </div>
        </div>
    </section>

    <section class="products section-padding product-list-section">
        <div class="container">

            <div class="section-head product-list-head">
                <div class="section-title left">
                    <p>Sản phẩm</p>
                    <h2>@(Model.SaleOnly ? "Sản phẩm đang sale" : "Danh sách sản phẩm")</h2>
                </div>

                <div class="product-list-actions">
                    <form class="product-search-form"
                          asp-controller="Home"
                          asp-action="SanPham"
                          method="get">

                        <input type="hidden" name="category" value="@Model.SelectedCategory" />
                        <input type="hidden" name="sort" value="@Model.SortOrder" />
                        <input type="hidden" name="saleOnly" value="@Model.SaleOnly.ToString().ToLower()" />

                        <input type="search"
                               name="keyword"
                               placeholder="Tìm áo thun, sơ mi, quần..."
                               value="@Model.Keyword" />

                        <button type="submit">
                            Tìm kiếm
                        </button>
                    </form>

                    @if (isAdmin)
                    {
                        <a class="manage-product-btn"
                           asp-controller="AdminProducts"
                           asp-action="Index">
                            Quản lý sản phẩm
                        </a>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Keyword))
            {
                <div class="search-result-note">
                    <span>
                        Tìm thấy @Model.Products.Count sản phẩm với từ khóa:
                        <strong>@Model.Keyword</strong>
                    </span>

                    <a asp-controller="Home"
                       asp-action="SanPham"
                       asp-route-category="@Model.SelectedCategory"
                       asp-route-sort="@Model.SortOrder"
                       asp-route-saleOnly="@Model.SaleOnly">
                        Xóa tìm kiếm
                    </a>
                </div>
            }
            else
            {
                <p class="product-count">
                    @(Model.SaleOnly
                        ? $"Tìm thấy {Model.Products.Count} sản phẩm đang sale"
                        : $"Tìm thấy {Model.Products.Count} sản phẩm")
                </p>
            }

            @if (!Model.Products.Any())
            {
                <div class="empty-state">
                    <h3>Không tìm thấy sản phẩm</h3>

                    @if (!string.IsNullOrWhiteSpace(Model.Keyword))
                    {
                        <p>
                            Không có sản phẩm nào phù hợp với từ khóa
                            <strong>@Model.Keyword</strong>.
                        </p>

                        <a class="btn btn-primary"
                           asp-controller="Home"
                           asp-action="SanPham">
                            Xem tất cả sản phẩm
                        </a>
                    }
                    else
                    {
                        <p>Hiện chưa có sản phẩm nào trong danh mục này.</p>
                    }

                    @if (isAdmin)
                    {
                        <a class="btn btn-primary"
                           style="margin-top: 18px;"
                           asp-controller="AdminProducts"
                           asp-action="Index">
                            Vào trang quản lý sản phẩm
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="product-grid">
                    @foreach (var product in Model.Products)
                    {
                        var salePercent = 0;

                        if (product.OldPrice > product.Price && product.OldPrice > 0)
                        {
                            salePercent = (int)Math.Round((double)((product.OldPrice - product.Price) / product.OldPrice * 100));
                        }

                        <article class="product-card">
                            <a class="product-img product-img-sale"
                               asp-controller="Home"
                               asp-action="ChiTietSanPham"
                               asp-route-id="@product.Id">

                                @if (salePercent > 0)
                                {
                                    <span class="sale-badge">
                                        -@salePercent%
                                    </span>
                                }

                                <img src="@product.ImageUrl" alt="@product.AltText" />
                            </a>

                            <div class="product-info">
                                <div class="product-tag-row">
                                    <p class="tag">@product.CategoryName</p>

                                    @if (salePercent > 0)
                                    {
                                        <span class="sale-mini-tag">
                                            Đang sale
                                        </span>
                                    }
                                </div>

                                <h3>
                                    <a asp-controller="Home"
                                       asp-action="ChiTietSanPham"
                                       asp-route-id="@product.Id">
                                        @product.Name
                                    </a>
                                </h3>

                                <div class="price-row @(salePercent > 0 ? "sale-price-row" : "")">
                                    <strong>@FormatPrice(product.Price)</strong>

                                    @if (salePercent > 0)
                                    {
                                        <span>@FormatPrice(product.OldPrice)</span>
                                    }
                                </div>

                                @if (salePercent > 0)
                                {
                                    <p class="sale-save-text">
                                        Tiết kiệm @FormatPrice(product.OldPrice - product.Price)
                                    </p>
                                }

                                <a class="product-detail-btn"
                                   asp-controller="Home"
                                   asp-action="ChiTietSanPham"
                                   asp-route-id="@product.Id">
                                    Xem chi tiết
                                </a>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>

</main>