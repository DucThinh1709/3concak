@model MenStyle.Web.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Sản phẩm";

    var isAdmin = User.Identity?.IsAuthenticated == true && User.IsInRole("Admin");

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main class="product-page">

    <section class="product-hero section-padding">
        <div class="container">
            <div class="product-hero-content">
                <p class="eyebrow">MENSTYLE SHOP</p>

                <h1>Sản phẩm thời trang nam</h1>

                <p>
                    Khám phá các mẫu áo thun, áo sơ mi, quần nam và áo khoác được chọn lọc
                    dành riêng cho phong cách nam hiện đại.
                </p>
            </div>
        </div>
    </section>

    <section class="products section-padding product-category-section">
        <div class="container">

            <div class="section-head product-page-head">
                <div class="section-title left">
                    <p>Danh mục</p>
                    <h2>Mua theo loại sản phẩm</h2>
                </div>

                <form asp-controller="Home"
                      asp-action="SanPham"
                      method="get"
                      class="toolbar product-toolbar">

                    <input type="hidden" name="category" value="@Model.SelectedCategory" />
                    <input type="hidden" name="keyword" value="@Model.Keyword" />

                    <select name="sort" onchange="this.form.submit()">
                        <option value="default" selected="@(Model.SortOrder == "default" ? "selected" : null)">
                            Sắp xếp mặc định
                        </option>

                        <option value="price-asc" selected="@(Model.SortOrder == "price-asc" ? "selected" : null)">
                            Giá thấp đến cao
                        </option>

                        <option value="price-desc" selected="@(Model.SortOrder == "price-desc" ? "selected" : null)">
                            Giá cao đến thấp
                        </option>
                    </select>
                </form>
            </div>

            <div class="category-grid product-category-grid">
                @foreach (var category in Model.Categories)
                {
                    <a class="category-card @(category.IsActive ? "active" : "")"
                       asp-controller="Home"
                       asp-action="SanPham"
                       asp-route-category="@category.Filter"
                       asp-route-sort="@Model.SortOrder"
                       asp-route-keyword="@Model.Keyword">

                        <span>@category.Number</span>

                        <h3>@category.Name</h3>

                        <p>@category.Description</p>
                    </a>
                }
            </div>

        </div>
    </section>

    <section class="products section-padding product-list-section">
        <div class="container">

            <div class="section-head product-list-head">
                <div class="section-title left">
                    <p>Sản phẩm</p>
                    <h2>Danh sách sản phẩm</h2>
                </div>

                <div class="product-list-actions">
                    <form class="product-search-form"
                          asp-controller="Home"
                          asp-action="SanPham"
                          method="get">

                        <input type="hidden" name="category" value="@Model.SelectedCategory" />
                        <input type="hidden" name="sort" value="@Model.SortOrder" />

                        <input type="search"
                               name="keyword"
                               placeholder="Tìm áo thun, sơ mi, quần..."
                               value="@Model.Keyword" />

                        <button type="submit">
                            Tìm kiếm
                        </button>
                    </form>

                    @if (isAdmin)
                    {
                        <a class="add-product-btn"
                           asp-controller="AdminProducts"
                           asp-action="Create">
                            + Thêm sản phẩm
                        </a>

                        <a class="manage-product-btn"
                           asp-controller="AdminProducts"
                           asp-action="Index">
                            Quản lý
                        </a>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Keyword))
            {
                <div class="search-result-note">
                    <span>
                        Tìm thấy @Model.Products.Count sản phẩm với từ khóa:
                        <strong>@Model.Keyword</strong>
                    </span>

                    <a asp-controller="Home"
                       asp-action="SanPham"
                       asp-route-category="@Model.SelectedCategory"
                       asp-route-sort="@Model.SortOrder">
                        Xóa tìm kiếm
                    </a>
                </div>
            }
            else
            {
                <p class="product-count">
                    Tìm thấy @Model.Products.Count sản phẩm
                </p>
            }

            @if (!Model.Products.Any())
            {
                <div class="empty-state">
                    <h3>Không tìm thấy sản phẩm</h3>

                    @if (!string.IsNullOrWhiteSpace(Model.Keyword))
                    {
                        <p>
                            Không có sản phẩm nào phù hợp với từ khóa
                            <strong>@Model.Keyword</strong>.
                        </p>

                        <a class="btn btn-primary"
                           asp-controller="Home"
                           asp-action="SanPham">
                            Xem tất cả sản phẩm
                        </a>
                    }
                    else
                    {
                        <p>Hiện chưa có sản phẩm nào trong danh mục này.</p>
                    }

                    @if (isAdmin)
                    {
                        <a class="btn btn-primary"
                           style="margin-top: 18px;"
                           asp-controller="AdminProducts"
                           asp-action="Create">
                            + Thêm sản phẩm mới
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="product-grid">
                    @foreach (var product in Model.Products)
                    {
                        <article class="product-card"
                                 data-category="@product.CategorySlug"
                                 data-name="@product.Name"
                                 data-price="@product.Price">

                            <div class="product-img">
                                <img src="@product.ImageUrl" alt="@product.AltText" />
                            </div>

                            <div class="product-info">
                                <p class="tag">@product.CategoryName</p>

                                <h3>@product.Name</h3>

                                <div class="price-row">
                                    <strong>@FormatPrice(product.Price)</strong>

                                    @if (product.OldPrice > 0)
                                    {
                                        <span>@FormatPrice(product.OldPrice)</span>
                                    }
                                </div>

                                <form asp-controller="Cart"
                                      asp-action="Add"
                                      asp-route-id="@product.Id"
                                      method="post">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@product.Id" />

                                    <input type="hidden"
                                           name="returnUrl"
                                           value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />

                                    <button class="add-cart" type="submit">
                                        Thêm vào giỏ
                                    </button>
                                </form>

                                @if (isAdmin)
                                {
                                    <div class="product-admin-actions">
                                        <a asp-controller="AdminProducts"
                                           asp-action="Edit"
                                           asp-route-id="@product.Id">
                                            Sửa
                                        </a>

                                        <a asp-controller="AdminProducts"
                                           asp-action="Delete"
                                           asp-route-id="@product.Id">
                                            Xóa
                                        </a>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }

        </div>
    </section>

</main>