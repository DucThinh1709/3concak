@model HomeViewModel

@{
    ViewData["Title"] = "MenStyle For Men";

    var heroImage = Model.HeroProduct?.ImageUrl ?? "/images/hero-fashion.svg";
    var heroAlt = Model.HeroProduct?.AltText ?? "MENSTYLE hero image";

    var introCards = new[]
    {
        new { Label = "Phong cách", Title = "Modern", Text = "Thiết kế dành cho nam giới trẻ trung, lịch lãm và năng động." },
        new { Label = "Sản phẩm", Title = "Đa dạng", Text = "Áo thun, sơ mi, quần nam, áo khoác và các item basic dễ phối." },
        new { Label = "Mua sắm", Title = "Dễ dùng", Text = "Khách hàng có thể xem sản phẩm, thêm vào giỏ và đặt hàng nhanh." },
        new { Label = "Quản trị", Title = "Rõ ràng", Text = "Có khu vực quản lý đơn hàng, sản phẩm, khách hàng và doanh thu." }
    };

    var sliderProducts = Model.SliderProducts.Any()
        ? Model.SliderProducts
        : Model.IntroProducts;
}

<main>
    <section id="home" class="hero">
        <div class="container hero-grid">
            <div class="hero-content">
                <p class="eyebrow">New Collection 2026</p>

                <h1>Thời trang nam hiện đại, lịch lãm và cá tính</h1>

                <p class="hero-desc">
                    Demo website bán quần áo nam với bố cục thương mại điện tử:
                    trang chủ giới thiệu thương hiệu, trang sản phẩm riêng, giỏ hàng,
                    checkout và khu vực quản trị.
                </p>

                <div class="hero-actions">
                    <a class="btn btn-primary"
                       asp-controller="Home"
                       asp-action="SanPham">
                        Mua ngay
                    </a>

                    <a class="btn btn-outline"
                       asp-controller="Home"
                       asp-action="BoSuuTap">
                        Xem bộ sưu tập
                    </a>
                </div>

                <div class="hero-stats">
                    <div>
                        <strong>120+</strong>
                        <span>Mẫu sản phẩm</span>
                    </div>

                    <div>
                        <strong>4.8/5</strong>
                        <span>Đánh giá</span>
                    </div>

                    <div>
                        <strong>24h</strong>
                        <span>Giao nội thành</span>
                    </div>
                </div>
            </div>

            <div class="hero-card">
                <div class="hero-image-frame">
                    <img src="@heroImage" alt="@heroAlt" />
                </div>

                <div class="floating-card sale-card">
                    <span>Flash Sale</span>
                    <strong>-30%</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="home-overview-section">
        <div class="container">
            <div class="section-title">
                <p>MenStyle Shop</p>
                <h2>Trang chủ giới thiệu tổng quan cửa hàng</h2>
            </div>

            <div class="overview-product-grid">
                @for (int i = 0; i < introCards.Length; i++)
                {
                    var card = introCards[i];
                    var product = Model.IntroProducts.ElementAtOrDefault(i);

                    var imageUrl = product?.ImageUrl ?? "/images/hero-fashion.svg";
                    var imageAlt = product?.AltText ?? card.Title;

                    <article class="overview-product-card">
                        <div class="overview-card-image">
                            <img src="@imageUrl" alt="@imageAlt" />
                        </div>

                        <div class="overview-card-content">
                            <span>@card.Label</span>
                            <strong>@card.Title</strong>
                            <p>@card.Text</p>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section id="collection" class="home-product-marquee-section">
        <div class="container">
            <div class="product-marquee-layout">
                <div class="product-marquee-content">
                    <p class="eyebrow">Smart Casual</p>

                    <h2>Phối đồ đi học, đi làm, đi chơi đều ổn</h2>

                    <p>
                        Khám phá các sản phẩm nổi bật của MENSTYLE với phong cách hiện đại,
                        dễ phối đồ và phù hợp nhiều hoàn cảnh.
                    </p>

                    <a class="btn btn-primary"
                       asp-controller="Home"
                       asp-action="SanPham">
                        Xem sản phẩm
                    </a>
                </div>

                <div class="product-marquee-box">
                    @if (sliderProducts.Any())
                    {
                        <div class="product-marquee-track">
                            @foreach (var product in sliderProducts.Concat(sliderProducts))
                            {
                                <a class="marquee-product-card"
                                   asp-controller="Home"
                                   asp-action="ChiTietSanPham"
                                   asp-route-id="@product.Id">
                                    <img src="@product.ImageUrl" alt="@product.AltText" />
                                    <span>@product.Name</span>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-marquee">
                            Chưa có sản phẩm để hiển thị.
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (User.IsInRole("Admin"))
    {
        <section id="admin-preview" class="admin-preview section-padding">
            <div class="container">
                <div class="section-title">
                    <p>Admin Dashboard</p>
                    <h2>Khu vực quản trị</h2>
                </div>

                <div class="dashboard-grid">
                    @foreach (var metric in Model.Metrics)
                    {
                        <div class="metric-card">
                            <span>@metric.Title</span>
                            <strong>@metric.Value</strong>
                            <p>@metric.Note</p>
                        </div>
                    }
                </div>

                <div class="admin-table-card">
                    <div class="table-head">
                        <h3>Đơn hàng gần đây</h3>

                        <a class="admin-table-btn"
                           asp-controller="AdminOrders"
                           asp-action="Index">
                            Quản lý đơn
                        </a>
                    </div>

                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Khách hàng</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (!Model.RecentOrders.Any())
                                {
                                    <tr>
                                        <td colspan="4">Chưa có đơn hàng nào.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td>@order.Code</td>
                                            <td>@order.CustomerName</td>
                                            <td>@order.Total</td>
                                            <td>
                                                <span class="status @order.StatusCssClass">
                                                    @order.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    }
</main>