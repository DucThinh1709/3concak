@model HomeViewModel
@{
    ViewData["Title"] = "Demo Website Bán Quần Áo Nam";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main>
    <section id="home" class="hero">
        <div class="container hero-grid">
            <div class="hero-content">
                <p class="eyebrow">New Collection 2026</p>
                <h1>Thời trang nam hiện đại, lịch lãm và cá tính</h1>
                <p class="hero-desc">
                    Demo website bán quần áo nam với bố cục thương mại điện tử: danh mục,
                    sản phẩm nổi bật, giỏ hàng, checkout và khu vực quản trị.
                </p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="#products">Mua ngay</a>
                    <a class="btn btn-outline" href="#collection">Xem bộ sưu tập</a>
                </div>
                <div class="hero-stats">
                    <div><strong>120+</strong><span>Mẫu sản phẩm</span></div>
                    <div><strong>4.8/5</strong><span>Đánh giá</span></div>
                    <div><strong>24h</strong><span>Giao nội thành</span></div>
                </div>
            </div>

            <div class="hero-card">
                <div class="hero-image-frame">
                    <img src="~/images/hero-fashion.svg" alt="Nam mặc thời trang hiện đại" asp-append-version="true" />
                </div>
                <div class="floating-card sale-card">
                    <span>Flash Sale</span>
                    <strong>-30%</strong>
                </div>
                <div class="floating-card style-card">
                    <span>Style</span>
                    <strong>Smart Casual</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="categories section-padding">
        <div class="container">
            <div class="section-title">
                <p>Danh mục</p>
                <h2>Mua theo phong cách của bạn</h2>
            </div>

            <div class="category-grid">
                @foreach (var category in Model.Categories)
                {
                    <article class="category-card @(category.IsActive ? "active" : "")" data-filter="@category.Filter">
                        <span>@category.Number</span>
                        <h3>@category.Name</h3>
                        <p>@category.Description</p>
                    </article>
                }
            </div>
        </div>
    </section>

    <section id="products" class="products section-padding">
        <div class="container">
            <div class="section-head">
                <div class="section-title left">
                    <p>Sản phẩm</p>
                    <h2>Sản phẩm nổi bật</h2>
                </div>
                <div class="toolbar">
                    <input id="searchInput" type="search" placeholder="Tìm áo thun, sơ mi..." />
                    <select id="sortSelect">
                        <option value="default">Sắp xếp mặc định</option>
                        <option value="low-high">Giá thấp đến cao</option>
                        <option value="high-low">Giá cao đến thấp</option>
                    </select>
                </div>
            </div>

            <div id="productGrid" class="product-grid">
                @foreach (var product in Model.Products)
                {
                    <article class="product-card"
                             data-category="@product.CategorySlug"
                             data-name="@product.Name"
                             data-price="@product.Price">
                        <div class="product-img">
                            <img src="@product.ImageUrl" alt="@product.AltText" />
                        </div>
                        <div class="product-info">
                            <p class="tag">@product.CategoryName</p>
                            <h3>@product.Name</h3>
                            <div class="price-row">
                                <strong>@FormatPrice(product.Price)</strong>
                                <span>@FormatPrice(product.OldPrice)</span>
                            </div>
                            <button class="add-cart" type="button">Thêm vào giỏ</button>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section id="collection" class="collection section-padding">
        <div class="container collection-grid">
            <div class="collection-banner dark">
                <p>Smart Casual</p>
                <h2>Phối đồ đi học, đi làm, đi chơi đều ổn</h2>
                <a href="#products">Khám phá ngay →</a>
            </div>
            <div class="collection-banner light">
                <p>Best Seller</p>
                <h2>Áo thun basic và sơ mi Oxford đang được yêu thích</h2>
                <a href="#products">Xem sản phẩm →</a>
            </div>
        </div>
    </section>

    <section class="checkout-demo section-padding">
        <div class="container checkout-grid">
            <div>
                <div class="section-title left">
                    <p>Quy trình mua hàng</p>
                    <h2>Luồng chức năng khách hàng</h2>
                </div>
                <div class="timeline">
                    <div><span>1</span><p>Xem danh sách sản phẩm</p></div>
                    <div><span>2</span><p>Chọn size, màu và thêm vào giỏ hàng</p></div>
                    <div><span>3</span><p>Nhập thông tin giao hàng</p></div>
                    <div><span>4</span><p>Đặt hàng và theo dõi trạng thái đơn</p></div>
                </div>
            </div>

            <form class="checkout-card">
                <h3>Demo thanh toán</h3>
                <label for="fullName">Họ tên</label>
                <input id="fullName" type="text" placeholder="Nguyễn Văn A">
                <label for="phone">Số điện thoại</label>
                <input id="phone" type="text" placeholder="0909 123 456">
                <label for="address">Địa chỉ giao hàng</label>
                <textarea id="address" placeholder="Nhập địa chỉ nhận hàng"></textarea>
                <button type="button" class="btn btn-primary full">Xác nhận đặt hàng</button>
            </form>
        </div>
    </section>

    <section id="admin-preview" class="admin-preview section-padding">
        <div class="container">
            <div class="section-title">
                <p>Admin Dashboard</p>
                <h2>Khu vực quản trị mẫu</h2>
            </div>

            <div class="dashboard-grid">
                @foreach (var metric in Model.Metrics)
                {
                    <div class="metric-card">
                        <span>@metric.Title</span>
                        <strong>@metric.Value</strong>
                        <p>@metric.Note</p>
                    </div>
                }
            </div>

            <div class="admin-table-card">
                <div class="table-head">
                    <h3>Đơn hàng gần đây</h3>
                    <button type="button">Quản lý đơn</button>
                </div>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td>@order.Code</td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.Total</td>
                                    <td><span class="status @order.StatusCssClass">@order.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</main>
