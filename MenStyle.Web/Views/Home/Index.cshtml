@model HomeViewModel

@{
    ViewData["Title"] = "Demo Website Bán Quần Áo Nam";
}

<main>
    <section id="home" class="hero">
        <div class="container hero-grid">
            <div class="hero-content">
                <p class="eyebrow">New Collection 2026</p>

                <h1>Thời trang nam hiện đại, lịch lãm và cá tính</h1>

                <p class="hero-desc">
                    Demo website bán quần áo nam với bố cục thương mại điện tử:
                    trang chủ giới thiệu thương hiệu, trang sản phẩm riêng, giỏ hàng,
                    checkout và khu vực quản trị.
                </p>

                <div class="hero-actions">
                    <a class="btn btn-primary"
                       asp-controller="Home"
                       asp-action="SanPham">
                        Mua ngay
                    </a>

                    <a class="btn btn-outline" href="#collection">
                        Xem bộ sưu tập
                    </a>
                </div>

                <div class="hero-stats">
                    <div>
                        <strong>120+</strong>
                        <span>Mẫu sản phẩm</span>
                    </div>

                    <div>
                        <strong>4.8/5</strong>
                        <span>Đánh giá</span>
                    </div>

                    <div>
                        <strong>24h</strong>
                        <span>Giao nội thành</span>
                    </div>
                </div>
            </div>

            <div class="hero-card">
                <div class="hero-image-frame">
                    <img src="~/images/hero-fashion.svg"
                         alt="Nam mặc thời trang hiện đại"
                         asp-append-version="true" />
                </div>

                <div class="floating-card sale-card">
                    <span>Flash Sale</span>
                    <strong>-30%</strong>
                </div>

                <div class="floating-card style-card">
                    <span>Style</span>
                    <strong>Smart Casual</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="home-intro section-padding">
        <div class="container">
            <div class="section-title">
                <p>MenStyle Shop</p>
                <h2>Trang chủ giới thiệu tổng quan cửa hàng</h2>
            </div>

            <div class="dashboard-grid">
                <div class="metric-card">
                    <span>Phong cách</span>
                    <strong>Modern</strong>
                    <p>Thiết kế dành cho nam giới trẻ trung, lịch lãm và năng động.</p>
                </div>

                <div class="metric-card">
                    <span>Sản phẩm</span>
                    <strong>Đa dạng</strong>
                    <p>Áo thun, sơ mi, quần nam, áo khoác và các item basic dễ phối.</p>
                </div>

                <div class="metric-card">
                    <span>Mua sắm</span>
                    <strong>Dễ dùng</strong>
                    <p>Khách hàng có thể xem sản phẩm, thêm vào giỏ và đặt hàng nhanh.</p>
                </div>

                <div class="metric-card">
                    <span>Quản trị</span>
                    <strong>Rõ ràng</strong>
                    <p>Có khu vực quản lý đơn hàng, sản phẩm, khách hàng và doanh thu.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="collection" class="collection section-padding">
        <div class="container collection-grid">
            <div class="collection-banner dark">
                <p>Smart Casual</p>

                <h2>Phối đồ đi học, đi làm, đi chơi đều ổn</h2>

                <a asp-controller="Home"
                   asp-action="SanPham">
                    Khám phá ngay →
                </a>
            </div>

            <div class="collection-banner light">
                <p>Best Seller</p>

                <h2>Áo thun basic và sơ mi Oxford đang được yêu thích</h2>

                <a asp-controller="Home"
                   asp-action="SanPham">
                    Xem sản phẩm →
                </a>
            </div>
        </div>
    </section>

    <section class="checkout-demo section-padding">
        <div class="container checkout-grid">
            <div>
                <div class="section-title left">
                    <p>Quy trình mua hàng</p>
                    <h2>Luồng chức năng khách hàng</h2>
                </div>

                <div class="timeline">
                    <div>
                        <span>1</span>
                        <p>Xem danh sách sản phẩm ở trang Sản phẩm</p>
                    </div>

                    <div>
                        <span>2</span>
                        <p>Chọn sản phẩm và thêm vào giỏ hàng</p>
                    </div>

                    <div>
                        <span>3</span>
                        <p>Nhập thông tin giao hàng</p>
                    </div>

                    <div>
                        <span>4</span>
                        <p>Đặt hàng và theo dõi trạng thái đơn</p>
                    </div>
                </div>

                <div style="margin-top: 28px;">
                    <a class="btn btn-primary"
                       asp-controller="Home"
                       asp-action="SanPham">
                        Đi đến trang sản phẩm
                    </a>
                </div>
            </div>

            <form class="checkout-card">
                <h3>Demo thanh toán</h3>

                <label for="fullName">Họ tên</label>
                <input id="fullName"
                       type="text"
                       placeholder="Nguyễn Văn A" />

                <label for="phone">Số điện thoại</label>
                <input id="phone"
                       type="text"
                       placeholder="0909 123 456" />

                <label for="address">Địa chỉ giao hàng</label>
                <textarea id="address"
                          placeholder="Nhập địa chỉ nhận hàng"></textarea>

                <button type="button" class="btn btn-primary full">
                    Xác nhận đặt hàng
                </button>
            </form>
        </div>
    </section>

    <section id="admin-preview" class="admin-preview section-padding">
        <div class="container">
            <div class="section-title">
                <p>Admin Dashboard</p>
                <h2>Khu vực quản trị mẫu</h2>
            </div>

            <div class="dashboard-grid">
                @foreach (var metric in Model.Metrics)
                {
                    <div class="metric-card">
                        <span>@metric.Title</span>
                        <strong>@metric.Value</strong>
                        <p>@metric.Note</p>
                    </div>
                }
            </div>

            <div class="admin-table-card">
                <div class="table-head">
                    <h3>Đơn hàng gần đây</h3>
                    <button type="button">Quản lý đơn</button>
                </div>

                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td>@order.Code</td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.Total</td>
                                    <td>
                                        <span class="status @order.StatusCssClass">
                                            @order.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</main>