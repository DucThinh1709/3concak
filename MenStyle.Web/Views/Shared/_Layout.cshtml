@using MenStyle.Web.Models
@using Microsoft.AspNetCore.Identity
@using MenStyle.Web.Extensions
@using MenStyle.Web.ViewModels
@using MenStyle.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;

    int cartQuantity = 0;

    if (currentUser is not null)
    {
        cartQuantity = await DbContext.ShoppingCartItems
            .Where(x => x.UserId == currentUser.Id)
            .SumAsync(x => (int?)x.Quantity) ?? 0;
    }
    ApplicationUser? layoutUser = null;
    string layoutDisplayName = "";
    string layoutAvatarUrl = "";
    string layoutAvatarInitial = "U";

    if (User.Identity?.IsAuthenticated == true)
    {
        layoutUser = await UserManager.GetUserAsync(User);

        layoutDisplayName = !string.IsNullOrWhiteSpace(layoutUser?.FullName)
            ? layoutUser.FullName
            : User.Identity.Name ?? "Tài khoản";

        layoutAvatarUrl = layoutUser?.AvatarUrl ?? "";

        layoutAvatarInitial = !string.IsNullOrWhiteSpace(layoutDisplayName)
            ? layoutDisplayName.Trim()[0].ToString().ToUpper()
            : "U";
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MENSTYLE</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header class="site-header">
        <div class="topbar">
            <span>Miễn phí vận chuyển cho đơn từ 499.000đ</span>
            <span>Hotline: 0909 123 456</span>
        </div>

        <nav class="navbar container">
            <a class="logo"
               asp-controller="Home"
               asp-action="Index"
               asp-fragment="home">
                MEN<span>STYLE</span>
            </a>

            <button class="mobile-toggle" aria-label="Mở menu">
                ☰
            </button>

            <div class="nav-links">
                <a asp-controller="Home"
                   asp-action="Index"
                   asp-fragment="home">
                    Trang chủ
                </a>

                <div class="nav-mega-item">
                    <a class="nav-link mega-trigger"
                       asp-controller="Home"
                       asp-action="SanPham">
                        Sản phẩm <span>⌄</span>
                    </a>

                    <div class="mega-menu">
                        <div class="mega-menu-inner">
                            <div class="mega-column">
                                <h3>ÁO NAM</h3>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-category="ao-thun">
                                    Áo Thun
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Áo Polo">
                                    Áo Polo
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-category="ao-so-mi">
                                    Áo Sơ mi
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-category="ao-khoac">
                                    Áo Khoác
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Hoodie">
                                    Hoodie
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Set đồ">
                                    Set đồ
                                </a>
                            </div>

                            <div class="mega-column">
                                <h3>QUẦN NAM</h3>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-category="quan-nam">
                                    Quần Jean
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Quần Short">
                                    Quần Short
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Quần Kaki">
                                    Quần Kaki & Chino
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Quần Jogger">
                                    Quần Jogger
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Quần Tây">
                                    Quần Tây
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Set đồ">
                                    Set Đồ
                                </a>
                            </div>

                            <div class="mega-column mega-highlight">
                                <h3>HÀNG MỚI</h3>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-sort="default">
                                    Sản phẩm mới nhất
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="basic">
                                    Basic dễ phối
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="oversize">
                                    Oversize
                                </a>

                                <a class="mega-sale-link" asp-controller="Home" asp-action="SanPham" asp-route-saleOnly="true">
                                    Đang sale
                                </a>

                            </div>

                            <div class="mega-column">
                                <h3>HÀNG BÁN CHẠY</h3>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Áo thun">
                                    Áo thun bán chạy
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Áo sơ mi">
                                    Sơ mi được yêu thích
                                </a>

                                <a asp-controller="Home" asp-action="SanPham" asp-route-keyword="Áo khoác">
                                    Áo khoác nổi bật
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <a asp-controller="Home" 
                   asp-action="BoSuuTap">
                   Bộ sưu tập
               </a>

            </div>

            <div class="nav-actions">
                <a class="cart-btn"
                   asp-controller="Cart"
                   asp-action="Index">
                    Giỏ hàng <span id="cartCount">@cartQuantity</span>
                </a>

                @if (currentUser is not null)
                {
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="nav-profile-link"
                           asp-controller="Account"
                           asp-action="Profile">

                            <span class="nav-avatar">
                                @if (!string.IsNullOrWhiteSpace(layoutAvatarUrl))
                                {
                                    <img src="@layoutAvatarUrl" alt="Ảnh đại diện" />
                                }
                                else
                                {
                                    <span>@layoutAvatarInitial</span>
                                }
                            </span>

                            <span class="nav-profile-text">
                                Xin chào, @layoutDisplayName
                            </span>
                        </a>
                    }
                    else
                    {
                        <a class="nav-login-link"
                           asp-controller="Account"
                           asp-action="Login">
                            Đăng nhập
                        </a>
                    }

                    <a class="nav-pill"
                       asp-controller="Account"
                       asp-action="MyOrders">
                        Đơn hàng
                    </a>

                    <form class="logout-form"
                          asp-controller="Account"
                          asp-action="Logout"
                          method="post">
                        @Html.AntiForgeryToken()

                        <button type="submit">
                            Đăng xuất
                        </button>
                    </form>
                }
                else
                {
                    <a class="nav-pill"
                       asp-controller="Account"
                       asp-action="Login">
                        Đăng nhập
                    </a>

                    <a class="nav-pill dark-pill"
                       asp-controller="Account"
                       asp-action="Register">
                        Đăng ký
                    </a>
                }
            </div>
        </nav>
    </header>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="flash-message success">
            @successMessage
        </div>
    }

    @RenderBody()

    <footer id="contact" class="footer">
        <div class="container footer-grid">
            <div>
                <a class="logo footer-logo"
                   asp-controller="Home"
                   asp-action="Index"
                   asp-fragment="home">
                    MEN<span>STYLE</span>
                </a>

                <p>
                    Website demo bán quần áo nam dành cho đồ án thiết kế giao diện
                    và web nâng cao.
                </p>
            </div>

            <div>
                <h4>Chính sách</h4>
                <a href="#">Đổi trả</a>
                <a href="#">Vận chuyển</a>
                <a href="#">Bảo mật</a>
            </div>

            <div>
                <h4>Liên hệ</h4>
                <p>Email: support@menstyle.vn</p>
                <p>Hotline: 0909 123 456</p>
            </div>
        </div>
    </footer>

    <div id="toast" class="toast">
        Đã thêm sản phẩm vào giỏ hàng
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_Chatbot" />
</body>
</html>