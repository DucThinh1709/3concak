@model MenStyle.Web.Models.CustomerOrder

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }

    var statuses = ViewBag.Statuses as List<string> ?? new List<string>();
}

<main class="order-success-page">
    <div class="container">

        <section class="order-success-card">
            <p class="eyebrow">ADMIN ORDER</p>
            <h1>@Model.OrderCode</h1>
            <p class="success-desc">
                Chi tiết đơn hàng của khách và cập nhật trạng thái xử lý.
            </p>
        </section>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="flash-message success">@successMessage</div>
        }

        <section class="order-detail-layout">
            <div class="order-detail-main">
                <div class="order-box">
                    <h2>Sản phẩm trong đơn</h2>

                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item-row">
                            <div>
                                <h3>@item.ProductName</h3>
                                <p>Số lượng: @item.Quantity</p>
                                <p>Đơn giá: @FormatPrice(item.Price)</p>
                            </div>

                            <strong>@FormatPrice(item.LineTotal)</strong>
                        </div>
                    }
                </div>
            </div>

            <aside class="order-detail-side">
                <div class="order-box">
                    <h2>Thông tin đơn</h2>

                    <div class="info-row">
                        <span>Khách hàng</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div class="info-row">
                        <span>SĐT</span>
                        <strong>@Model.PhoneNumber</strong>
                    </div>

                    <div class="info-row">
                        <span>Địa chỉ</span>
                        <strong>@Model.ShippingAddress</strong>
                    </div>

                    <div class="info-row">
                        <span>Ngày đặt</span>
                        <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>

                    <div class="order-total-row">
                        <span>Tổng tiền</span>
                        <strong>@FormatPrice(Model.TotalAmount)</strong>
                    </div>

                    <form asp-controller="AdminOrders"
                          asp-action="UpdateStatus"
                          asp-route-id="@Model.Id"
                          method="post">

                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label>Trạng thái đơn hàng</label>
                            <select name="status" class="form-control">
                                @foreach (var status in statuses)
                                {
                                    <option value="@status" selected="@(status == Model.Status)">
                                        @status
                                    </option>
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary full mt-12">
                            Cập nhật trạng thái
                        </button>
                    </form>

                    <a class="btn btn-outline full mt-12"
                       asp-controller="AdminOrders"
                       asp-action="Index">
                        Quay lại danh sách
                    </a>
                </div>
            </aside>
        </section>

    </div>
</main>