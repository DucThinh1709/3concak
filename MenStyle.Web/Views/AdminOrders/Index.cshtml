@model List<MenStyle.Web.Models.CustomerOrder>

@{
    ViewData["Title"] = "Quản lý đơn hàng";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main class="admin-crud-page">
    <div class="container">

        <div class="admin-crud-header">
            <div>
                <p class="eyebrow">ADMIN</p>
                <h1>Quản lý đơn hàng</h1>
                <p>Xem đơn hàng khách đã đặt và xử lý trạng thái.</p>
            </div>

            <a class="btn btn-outline" asp-controller="AdminProducts" asp-action="Index">
                Quản lý sản phẩm
            </a>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="flash-message success">@successMessage</div>
        }

        <div class="admin-crud-card">
            <table class="admin-crud-table">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Số SP</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-table">Chưa có đơn hàng.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>@order.OrderCode</strong></td>
                                <td>
                                    <strong>@order.CustomerName</strong>
                                    <small>@order.PhoneNumber</small>
                                </td>
                                <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.Items.Sum(i => i.Quantity)</td>
                                <td>@FormatPrice(order.TotalAmount)</td>
                                <td>@order.Status</td>
                                <td>
                                    <a class="edit-btn"
                                       asp-controller="AdminOrders"
                                       asp-action="Details"
                                       asp-route-id="@order.Id">
                                        Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>
</main>