@model List<MenStyle.Web.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<section class="admin-crud-page">
    <div class="container">
        <div class="admin-crud-header">
            <div>
                <p class="eyebrow">ADMIN</p>
                <h1>Quản lý sản phẩm</h1>
                <p>Thêm, sửa, xóa sản phẩm dành riêng cho quản trị viên.</p>
            </div>

            <a class="btn btn-primary"
               asp-controller="AdminProducts"
               asp-action="Create">
                + Thêm sản phẩm
            </a>
        </div>

        <div class="admin-crud-card">
            <div class="table-responsive">
                <table class="admin-crud-table">
                    <thead>
                        <tr>
                            <th>Ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá bán</th>
                            <th>Giá cũ</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="empty-table">
                                    Chưa có sản phẩm nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td>
                                        <img class="admin-product-img"
                                             src="@product.ImageUrl"
                                             alt="@product.AltText" />
                                    </td>

                                    <td>
                                        <strong>@product.Name</strong>
                                        <small>@product.CategorySlug</small>
                                    </td>

                                    <td>@product.CategoryName</td>

                                    <td>@FormatPrice(product.Price)</td>

                                    <td>@FormatPrice(product.OldPrice)</td>

                                    <td>
                                        <div class="admin-actions">
                                            <a class="edit-btn"
                                               asp-controller="AdminProducts"
                                               asp-action="Edit"
                                               asp-route-id="@product.Id">
                                                Sửa
                                            </a>

                                            <a class="delete-btn"
                                               asp-controller="AdminProducts"
                                               asp-action="Delete"
                                               asp-route-id="@product.Id">
                                                Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>