@model List<MenStyle.Web.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";

    string FormatPrice(decimal price)
    {
        return $"{price:N0}đ".Replace(",", ".");
    }
}

<main class="admin-crud-page">
    <div class="container">

        <div class="admin-crud-header">
            <div>
                <p class="eyebrow">ADMIN</p>
                <h1>Quản lý sản phẩm</h1>
                <p>Thêm, sửa, xóa và bật/tắt sản phẩm trong SQL Server.</p>
            </div>

            <a class="btn btn-primary" asp-controller="AdminProducts" asp-action="Create">
                Thêm sản phẩm
            </a>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="flash-message success">@successMessage</div>
        }

        <div class="admin-crud-card">
            <table class="admin-crud-table">
                <thead>
                    <tr>
                        <th>Ảnh</th>
                        <th>Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-table">Chưa có sản phẩm nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var product in Model)
                        {
                            <tr>
                                <td>
                                    <img class="admin-product-img" src="@product.ImageUrl" alt="@product.AltText" />
                                </td>

                                <td>
                                    <strong>@product.Name</strong>
                                    <small>ID: @product.Id</small>
                                </td>

                                <td>
                                    <strong>@product.CategoryName</strong>
                                    <small>@product.CategorySlug</small>
                                </td>

                                <td>
                                    <strong>@FormatPrice(product.Price)</strong>
                                    @if (product.OldPrice > product.Price)
                                    {
                                        <small>Giá cũ: @FormatPrice(product.OldPrice)</small>
                                    }
                                </td>

                                <td>
                                    @(product.IsActive ? "Đang hiển thị" : "Đang ẩn")
                                </td>

                                <td>
                                    <div class="admin-actions">
                                        <a class="edit-btn"
                                           asp-controller="AdminProducts"
                                           asp-action="Edit"
                                           asp-route-id="@product.Id">
                                            Sửa
                                        </a>

                                        <a class="delete-btn"
                                           asp-controller="AdminProducts"
                                           asp-action="Delete"
                                           asp-route-id="@product.Id">
                                            Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>
</main>