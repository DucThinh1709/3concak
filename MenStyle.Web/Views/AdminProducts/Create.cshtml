@model MenStyle.Web.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<main class="admin-crud-page">
    <div class="container">

        <div class="admin-crud-header">
            <div>
                <p class="eyebrow">ADMIN</p>
                <h1>Thêm sản phẩm</h1>
                <p>Thêm sản phẩm mới vào bảng Products.</p>
            </div>

            <a class="btn btn-outline" asp-controller="AdminProducts" asp-action="Index">
                Quay lại
            </a>
        </div>

        <form asp-controller="AdminProducts" asp-action="Create" method="post" class="admin-form-card">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger validation-box"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Name">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="CategoryName">Tên danh mục</label>
                    <input asp-for="CategoryName" class="form-control" placeholder="Áo thun" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CategorySlug">Mã danh mục</label>
                    <input asp-for="CategorySlug" class="form-control" placeholder="ao-thun" />
                    <span asp-validation-for="CategorySlug" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price">Giá bán</label>
                    <input asp-for="Price" class="form-control" type="number" min="0" step="1000" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="OldPrice">Giá cũ</label>
                    <input asp-for="OldPrice" class="form-control" type="number" min="0" step="1000" />
                    <span asp-validation-for="OldPrice" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ImageUrl">Đường dẫn ảnh</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="/images/product-tshirt.svg" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="AltText">Mô tả ảnh</label>
                <input asp-for="AltText" class="form-control" />
                <span asp-validation-for="AltText" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>
                    <input asp-for="IsActive" />
                    Đang hiển thị sản phẩm
                </label>
            </div>

            <button type="submit" class="btn btn-primary">
                Thêm sản phẩm
            </button>
        </form>

    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}